# SignalForge Environment Configuration
# Copy this file to .env and add your API keys

# Application Settings
APP_NAME=SignalForge API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
# For production (PostgreSQL):
# DATABASE_URL=postgresql://username:password@localhost:5432/signalforge

# For development (SQLite):
DATABASE_URL=sqlite:///./signalforge.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Clerk Authentication (REQUIRED for production)
CLERK_JWT_ISSUER=https://your-clerk-domain.clerk.accounts.dev
CLERK_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
# Add your Clerk public key here
-----END PUBLIC KEY-----
CLERK_API_KEY=sk_test_your_clerk_api_key

# AI Services
OPENAI_API_KEY=sk-your-openai-api-key
OPENROUTER_API_KEY=sk-your-openrouter-api-key
GEMINI_API_KEY=your-gemini-api-key

# Cache Configuration (in seconds)
CACHE_TTL_STOCK_DATA=600
CACHE_TTL_API_RESPONSE=300
CACHE_TTL_PORTFOLIO=180
CACHE_TTL_SIGNAL=300

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_REQUESTS_PER_DAY=10000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=

# Security
SECRET_KEY=your-super-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://your-domain.com

# External API Configuration
YFINANCE_TIMEOUT=30
YFINANCE_RETRY_ATTEMPTS=3

# Performance
MAX_WORKERS=4
REQUEST_TIMEOUT=60

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Note: At least one AI API key is required for AI explanations
# If no keys are provided, system will use local fallback explanations
# Clerk authentication is required for production environments
